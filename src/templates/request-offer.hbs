<div style="background-color: #e6eaf0">
  <div style="margin: 0px auto; max-width: 600px">
    <div style="padding: 20px 0;">
        <div style="background-color: #ffffff; border-radius: 6px; vertical-align: top; padding: 20px; margin: 20px 0">
          <table>
            <tbody>
              {{#each data}}
              <tr>
                <td style="padding: 0 0 10px 0; word-break: break-word;">
                  <div style="font-family: Arial, sans-serif; font-size: 15px; font-weight: 700; line-height: 1; text-align: left; color: #000000;">
                    {{@key}}
                  </div>
                </td>
              </tr>
              <tr>
                <td style="padding: 0; word-break: break-word;">
                  <div style="font-family: Arial, sans-serif; font-size: 15px; line-height: 1.4; text-align: left; color: rgba(0, 0, 0, 0.8);">
                    {{this}}
                  </div>
                </td>
              </tr>
              <tr>
                <td style="padding: 17px 0; word-break: break-word;">
                  <p style="border-top: solid 1px rgb(223, 223, 223); font-size: 1px; margin: 0px auto; width: 100%;"></p>
                </td>
              </tr>
              {{/each}}
              <!-- Submitted At -->
              <tr>
                <td style="padding: 0; word-break: break-word;">
                  <div style="font-family: Arial, sans-serif; font-size: 14px; line-height: 1; text-align: left; color: rgba(0, 0, 0, 0.42);">
                    Uhrzeit einreichen: {{submittedAt}}
                  </div>
                </td>
              </tr>
              <tr>
                <td style="padding: 17px 0; word-break: break-word;">
                  <p style="border-top: solid 1px rgb(223, 223, 223); font-size: 1px; margin: 0px auto; width: 100%;"></p>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
    </div>
  </div>
</div>
